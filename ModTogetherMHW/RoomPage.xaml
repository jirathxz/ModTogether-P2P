<Page x:Class="ModTogetherMHW.RoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="RoomPage">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="20" MinWidth="750">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column: Create Session (Host) -->
                <ui:Card Grid.Column="0" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock x:Name="TxtHostTitle" Text="Create Session (Host)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                        
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="PIN will appear after hosting" Foreground="#A0A0A0" VerticalAlignment="Center" x:Name="LblHostPin" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ComboBox x:Name="CmbIp" Width="140" Margin="0,0,6,0" Visibility="Collapsed" />
                                <ui:Button Content="IP" Icon="{ui:SymbolIcon Copy24}" Margin="0,0,6,0" x:Name="BtnCopyIp" Click="BtnCopyIp_Click" Visibility="Collapsed" ToolTip="Copy IP" />
                                <ui:Button Content="PIN" Icon="{ui:SymbolIcon Copy24}" x:Name="BtnCopyPin" Click="BtnCopyPin_Click" Visibility="Collapsed" ToolTip="Copy PIN" />
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,12">
                            <ui:ToggleSwitch Content="Custom PIN" x:Name="ToggleCustomPin" Checked="ToggleCustomPin_Changed" Unchecked="ToggleCustomPin_Changed" Margin="0,0,0,4"/>
                            <ui:TextBox PlaceholderText="Custom PIN (Max 6)" MaxLength="6" IsEnabled="False" x:Name="TxtCustomPin" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <ui:ToggleSwitch Content="Custom Port" x:Name="ToggleCustomPort" Checked="ToggleCustomPort_Changed" Unchecked="ToggleCustomPort_Changed" Margin="0,0,0,4"/>
                            <ui:TextBox PlaceholderText="Port (Default: 52100)" IsEnabled="False" x:Name="TxtCustomPort" />
                        </StackPanel>
                        
                        <ui:Button Content="Start Hosting" Icon="{ui:SymbolIcon Play24}" Appearance="Primary" HorizontalAlignment="Stretch" x:Name="BtnHost" Click="BtnHost_Click" Margin="0,0,0,16" />
                        
                        <Grid>
                            <TextBlock Text="Status: Ready" VerticalAlignment="Center" x:Name="LblHostStatus" />
                            <ui:Button Content="Kill Old Hosts" Icon="{ui:SymbolIcon Dismiss24}" HorizontalAlignment="Right" x:Name="BtnKillHost" Click="BtnKillHost_Click" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Right Column: Join Session (Client) -->
                <ui:Card Grid.Column="2" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock x:Name="TxtClientTitle" Text="Join Session (Client)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox PlaceholderText="Host IP (e.g. 192.168.1.5:52100)" x:Name="TxtIp" Grid.Column="0" Margin="0,0,8,0" />
                            <ui:Button Content="Scan LAN" Icon="{ui:SymbolIcon Search24}" x:Name="BtnScan" Grid.Column="1" Click="BtnScan_Click" />
                        </Grid>

                        <ui:TextBox PlaceholderText="6-Digit PIN" MaxLength="6" x:Name="TxtPin" Margin="0,0,0,16" />
                        
                        <ui:Button Content="Join" Icon="{ui:SymbolIcon Link24}" Appearance="Primary" HorizontalAlignment="Stretch" x:Name="BtnJoin" Click="BtnJoin_Click" />
                    </StackPanel>
                </ui:Card>
            </Grid>
        </ScrollViewer>

        <!-- LAN Scan Result Overlay -->
        <Grid x:Name="ScanOverlay" Visibility="Collapsed" Background="#80000000">
            <ui:Card VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20" MinWidth="300">
                <StackPanel>
                    <TextBlock Text="Select Host" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox x:Name="ListServers" MaxHeight="200" Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="Cancel" Click="BtnCancelScan_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Select" Appearance="Primary" Click="BtnSelectScan_Click" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>
