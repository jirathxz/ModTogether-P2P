<Page x:Class="ModTogetherMHW.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="ClientPage">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="20" MinWidth="400">
                <ui:Card Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Join Session (Client)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox PlaceholderText="Host IP (e.g. 192.168.1.5:52100)" x:Name="TxtIp" Grid.Column="0" Margin="0,0,8,0" />
                            <ui:Button Content="Scan LAN" Icon="{ui:SymbolIcon Search24}" x:Name="BtnScan" Grid.Column="1" Click="BtnScan_Click" />
                        </Grid>

                        <ui:TextBox PlaceholderText="6-Digit PIN" MaxLength="6" x:Name="TxtPin" Margin="0,0,0,16" />
                        
                        <ui:Button Content="Join" Icon="{ui:SymbolIcon Link24}" Appearance="Primary" HorizontalAlignment="Stretch" x:Name="BtnJoin" Click="BtnJoin_Click" />
                    </StackPanel>
                </ui:Card>
            </Grid>
        </ScrollViewer>

        <!-- LAN Scan Result Overlay -->
        <Grid x:Name="ScanOverlay" Visibility="Collapsed" Background="#80000000">
            <ui:Card VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20" MinWidth="300">
                <StackPanel>
                    <TextBlock Text="Select Host" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox x:Name="ListServers" MaxHeight="200" Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="Cancel" Click="BtnCancelScan_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Select" Appearance="Primary" Click="BtnSelectScan_Click" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>
