<Page x:Class="ModTogetherMHW.HostPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="HostPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="20" MinWidth="400">
            <ui:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="Create Session (Host)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                    
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="PIN will appear after hosting" Foreground="#A0A0A0" VerticalAlignment="Center" x:Name="LblHostPin" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ComboBox x:Name="CmbIp" Width="180" Margin="0,0,8,0" Visibility="Collapsed" />
                            <ui:Button Content="Copy IP" Icon="{ui:SymbolIcon Copy24}" Margin="0,0,8,0" x:Name="BtnCopyIp" Click="BtnCopyIp_Click" Visibility="Collapsed" />
                            <ui:Button Content="Copy PIN" Icon="{ui:SymbolIcon Copy24}" x:Name="BtnCopyPin" Click="BtnCopyPin_Click" Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>
                    
                    <StackPanel Margin="0,0,0,12">
                        <ui:ToggleSwitch Content="Custom PIN" x:Name="ToggleCustomPin" Checked="ToggleCustomPin_Changed" Unchecked="ToggleCustomPin_Changed" Margin="0,0,0,4"/>
                        <ui:TextBox PlaceholderText="Custom PIN (Max 6)" MaxLength="6" IsEnabled="False" x:Name="TxtCustomPin" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <ui:ToggleSwitch Content="Custom Port" x:Name="ToggleCustomPort" Checked="ToggleCustomPort_Changed" Unchecked="ToggleCustomPort_Changed" Margin="0,0,0,4"/>
                        <ui:TextBox PlaceholderText="Port (Default: 52100)" IsEnabled="False" x:Name="TxtCustomPort" />
                    </StackPanel>
                    
                    <ui:Button Content="Start Hosting" Icon="{ui:SymbolIcon Play24}" Appearance="Primary" HorizontalAlignment="Stretch" x:Name="BtnHost" Click="BtnHost_Click" Margin="0,0,0,16" />
                    
                    <Grid>
                        <TextBlock Text="Status: Ready" VerticalAlignment="Center" x:Name="LblHostStatus" />
                        <ui:Button Content="Kill Other Hosts" Icon="{ui:SymbolIcon Dismiss24}" HorizontalAlignment="Right" x:Name="BtnKillHost" Click="BtnKillHost_Click" />
                    </Grid>
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</Page>
